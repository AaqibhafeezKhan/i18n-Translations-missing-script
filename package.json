{
  "name": "i18n-translations-missing-script",
  "version": "2.0.0",
  "description": "A CLI tool to detect missing or untranslated i18n keys across multiple language files",
  "main": "dist/index.js",
  "bin": {
    "i18n-check": "./dist/index.js"
  },
  "scripts": {
    "start": "ts-node-dev --respawn ./src/index.ts --path ./sample/i18n --whitelist ./sample/whitelist.json --output ./sample/missed-translations.json --verbose",
    "dev": "ts-node-dev --respawn ./src/index.ts --path ./sample/i18n --whitelist ./sample/whitelist.json --output ./sample/missed-translations.json --verbose",
    "build": "tsc",
    "check": "ts-node ./src/index.ts",
    "sample": "ts-node ./src/index.ts --path ./sample/i18n --whitelist ./sample/whitelist.json --output ./sample/missed-translations.json --verbose",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "author": "",
  "license": "ISC",
  "keywords": [
    "i18n",
    "internationalization",
    "translations",
    "missing-translations",
    "localization",
    "l10n",
    "cli"
  ],
  "devDependencies": {
    "@types/node": "^18.0.0",
    "rimraf": "^5.0.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^4.9.5"
  }
}
